{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "remote",
      "ios": {
        "simulator": false,
        "entitlements": {
          "aps-environment": "development"
        }
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "remote"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "koh.kaw@icloud.com",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "HCF97943N8"
      }
    }
  }
}
